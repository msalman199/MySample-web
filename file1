# Create a least-privilege role for a CI/CD pipeline
resource "google_project_iam_custom_role" "cicd_deployer" {
  role_id     = "cicdDeployer"
  title       = "CI/CD Deployer"
  description = "Allows limited deploy actions to Cloud Run"
  permissions = [
    "run.services.create",
    "run.services.update",
    "storage.objects.get"
  ]
}

# Bind the role to a specific service account
resource "google_project_iam_binding" "deployer_binding" {
  project = "my-project"
  role    = google_project_iam_custom_role.cicd_deployer.id
  members = [
    "serviceAccount:deploy-sa@://gserviceaccount.com",
  ]
}
